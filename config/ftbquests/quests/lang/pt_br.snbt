	quest.22530C57215BC0AB.title: "&lO Assembler"
	quest.2281F1237556660F.quest_desc: ["Ao olhar para um ritual no livro guia de espíritos, a pré-visualização terá um pequeno ícone de olho no canto inferior esquerdo que você pode clicar para ativar a pré-visualização no mundo para você seguir"]
	quest.2281F1237556660F.quest_subtitle: "Foi aqui que você errou"
