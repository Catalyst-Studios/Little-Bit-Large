	quest.215E69CFA0425ADF.quest_subtitle: "NASv8: LIGADO"
	quest.215E69CFA0425ADF.title: "Componente de Armazenamento de 16M"
	quest.2164219E306DCCEA.quest_desc: [
		"O mod &l&1Explorer's Compass&r nos ajudará em nossa busca por &dEstruturas&r ou &6Dungeons&f, ele pode até localizar a nova estrutura da 1.21... As Ruínas de Trilha facilmente"
		""
		"Clique com o botão direito nesta bússola e uma nova GUI deve aparecer. Nesta nova GUI você pode procurar estruturas por mod ou pelo nome delas! Depois disso, ela lhe dirá a que distância a estrutura está."
		""
		"Funciona de forma semelhante à &2Nature's Compass&r, mas com estruturas"
		""
		"Mod criado por: &5Chaosyr"
	]
	quest.2164219E306DCCEA.quest_subtitle: "Bússola de estruturas"
	quest.2164219E306DCCEA.title: "&l&7Explorer's Compass"
