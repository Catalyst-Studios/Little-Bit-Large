		"[{\"text\":\"Bem, como antes, são 2 \",\"color\":\"#FFFFFF\"},{\"text\":\"Aprimoramentos de Ouro\",\"color\":\"#e6cd29\"},{\"text\":\" adicionados \",\"color\":\"#FFFFFF\"},{\"text\":\"juntos\",\"color\":\"#FF55FF\"}]"
