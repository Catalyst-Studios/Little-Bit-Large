	quest.13E38108EE8D35E6.quest_desc: ["Este tipo de componente de &carmazenamento&r é usado para armazenar muitos &dtipos&r, pois eles fornecem um equilíbrio entre &dtipos&r e a quantidade de itens que podem &carmazenar&r."]
	quest.13E38108EE8D35E6.quest_subtitle: "NASv.3: LIGADO"
	quest.14457BC2EC4E43C4.quest_desc: [
