	quest.14457BC2EC4E43C4.quest_subtitle: "destruidor de blocos?"
	quest.14457BC2EC4E43C4.title: "&lBloco Destruidor"
	quest.146104BABCD8DE9C.quest_desc: [
		"Mais uma picareta melhor, não elétrica infelizmente, mas com um visual bem chique!"
		""
		"Esta picareta tem 2 modos."
		""
