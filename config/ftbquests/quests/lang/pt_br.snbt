	quest.00BE99D7662A3CCE.quest_desc: [
		"&5Cada&r um tem 2 usos principais na &aentrada&r e &csaída&r:"
		""
		"- &6Lados&r -> Diz ao SFM para tentar com cada &5lado&r da etiqueta, útil onde você não sabe o lado"
		"Sintaxe: input from <label> each side"
		""
		"- &dEtiquetas&r -> Diz ao SFM para tentar o &aretain&r em cada etiqueta em vez de apenas 1 etiqueta"
		"Sintaxe: output retain 5 to each \"machine 👽\""
		""
		"Também existem alguns &eusos&r nas declarações IF"
		""
		"- &6IF&r -> Diz ao SFM para verificar a &bcondição&r em cada etiqueta"
		"Sintaxe: if each chest has eq 5 *stone* then"
	]
	quest.00ED21DA1BCBEC5A.quest_desc: [
		"Irá gerar source de plantações e árvores crescendo em um raio de 15 blocos, ou seja (área de 31x31x31 centrada no link)."
		""
		"Irá gerar Source extra de plantas/árvores do Ars Nouveau."
		""
		"Para plantações, a source é gerada a partir do crescimento da planta e não continuará a produzir source quando estiver totalmente madura."
		""
		"&eNOTA: não gerará source de plantações que são fertilizadas com farinha de osso, mas outros tipos de aceleração de crescimento ainda funcionam, árvores fertilizadas com farinha de osso ainda contribuirão.&r"
	]
	quest.00FF8AAFCC2E4533.quest_desc: [
