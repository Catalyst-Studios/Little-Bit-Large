	quest.6C70C640F57B50E5.title: "&lAdicional de Velocidade de Máquina"
	quest.6C7CE3884A3A134B.quest_desc: [
		"A refinaria é um multibloco que pode ter até 4 saídas de refinaria."
		"Coloque o controlador e, idealmente, 4 saídas no topo."
		"A refinaria requer apenas calor para operar, certifique-se de cobrir os lados abertos com isolamento térmico para não perder todo o calor."
		"&e(qualquer bloco funcionará como isolamento térmico, mas eles são mais organizados e você pode interagir com a máquina por trás deles.)&r"
		" "
	]
	quest.6C8BF92697A6F3AF.quest_desc: ["Nota: você pode adicionar &dmelhorias&r no lado de cima da &6colmeia&r ou &emáquinas&r usando &aPipez&r ou similar."]
	quest.6C8BF92697A6F3AF.quest_subtitle: "Baseando"
	quest.6CA5C21D757AA820.quest_desc: [
		"O anel da Vingança é o primeiro passo para lutar contra esses Espíritos da Vingança!"
		""
		"Precisaremos de um pouco de Ferro e um pouco de pó de Gema Negra para fabricá-lo, mas esta versão atrairá espíritos da vingança..."
	]
	quest.6CA72FFE06D0D4A2.quest_desc: [
		"Plástico do IF e do PNC foram unificados, isso significa que você pode usar plástico em vez disso, que é muito mais rápido e fácil de fazer."
		"O plástico é usado em vários componentes e blocos no pnc, como placas de circuito e várias máquinas"
	]
	quest.6CA72FFE06D0D4A2.quest_subtitle: "Atalho"
	quest.6CAC0EAE07BD6DD4.quest_subtitle: "Uma versão mais cara"
	quest.6CBD797B715195F9.quest_desc: [
		"Sendo nosso primeiro painel solar... não gerará uma quantidade enorme de FE..."
		""
		"                      &4&lMAS!&r"
		""
		"Quanto mais nos aprofundarmos neste mod, a geração de energia se tornará melhor, eu prometo."
		""
		"Algo importante a notar é que a taxa de transferência será muito maior que a taxa de geração."
		""
		"Outra coisa a lembrar é que esses painéis solares têm um buffer de energia interno, que é recomendado deixar enquanto ele gera mais energia!"
		""
		"E o mais importante, ele precisa de uma visão clara do sol."
	]
	quest.6CBD797B715195F9.quest_subtitle: "O Começo"
	quest.6CBD797B715195F9.title: "&lPainel Solar de Leadstone"
	quest.6CE09C4855A1B42F.quest_desc: ["&dMagia&r e &etecnologia&r são combinadas para obter &2urânio&r"]
	quest.6CE09C4855A1B42F.quest_subtitle: "Urânio"
	quest.6D00948588B44926.quest_desc: ["As &bvelas&r da vanilla dão &5+1.25% de Arcana&r por vela, enquanto as &bvelas grandes&r do Occultism dão &5+4% de Arcana&r por vela."]
	quest.6D00948588B44926.quest_subtitle: "Qual é o cheiro de areia rosa, afinal?"
	quest.6D00948588B44926.title: "&5Mais Arcana!"
	quest.6D20BEE603706F69.quest_desc: [
