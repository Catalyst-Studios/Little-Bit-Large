	quest.28BF9F410AEC0FEE.quest_subtitle: "Passo 2"
	quest.28CAF974575B6F8E.quest_desc: ["O broto &doriginal&r, sendo necessário em muitos &amods&r, você deve ter &cpelo menos&r um"]
