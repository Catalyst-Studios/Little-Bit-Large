	quest.14CB7FBA94CA9F72.title: "Geração de energia"
	quest.14D304CB811AF739.quest_desc: ["Algumas &6tábuas&r e &7barras de ferro&r te dão as &dbases&r para &carmazenamentos&r tremendos."]
	quest.14D304CB811AF739.quest_subtitle: "O universo na sua mão"
	quest.14F0BAE920CD792C.quest_desc: [
		"Transforma alguns &6minérios&r em sua forma &dfinal&r, como o minério de &credstone&r."
		""
		"Também &5permite&r que você &emelhore&r sua fábrica com a versão &denriquecida&r dos produtos químicos."
