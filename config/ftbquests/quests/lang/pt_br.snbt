	quest.1C8DEA9A74F3CB11.quest_desc: ["Aumenta a &acapacidade&r de &denergia&r e reduz o &6uso&r de &aenergia&r"]
	quest.1C8DEA9A74F3CB11.quest_subtitle: "Painéis solares"
	quest.1C966B51149B598F.title: "Abelha Magmática"
	quest.1CBB206BA9CDBF9C.quest_desc: ["&dPermite&r que você pegue &eitens&r da sua &amochila&r quando você clica com o botão do meio (se você os tiver) ou você pode &6selecionar&r qual &bslot&r você quer que seja &dpreenchido&r."]
