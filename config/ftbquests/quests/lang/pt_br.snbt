	quest.14F0BAE920CD792C.quest_subtitle: "Processamento de minério mais rápido"
	quest.150301896889C39C.quest_desc: [
		"&bReabasteça&r sua mochila se você &5agachar&r e &aclicar com o botão direito&r em um baú."
