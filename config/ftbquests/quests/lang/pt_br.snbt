	quest.0A570D70294358D0.title: "Melhorias/Configurações"
	quest.0A691F71CA79DCB0.quest_desc: [
		"Este é um dos meus tanques de fluido favoritos em todo o minecraft modificado, é bem barato e é incrivelmente semelhante aos Tanques do Mekanism!"
		""
		"Pode ser usado como um balde para colocar qualquer tipo de fluido."
		""
		"Outra coisa sobre este tanque é que se criarmos um segundo tanque, podemos combiná-lo em qualquer grade de criação para aumentar sua capacidade. Isso se aplica a qualquer tanque escuro que esteja abaixo de &61.024.000&rmB."
	]
	quest.0A691F71CA79DCB0.quest_subtitle: "Pode armazenar qualquer fluido"
	quest.0A691F71CA79DCB0.title: "Tanque Escuro"
	quest.0A7679A16AFCFE50.quest_desc: ["&dPermite&r que você &carmazene&r 8 vezes mais em cada &6slot&r"]
