	quest.149709E58A23B4BE.quest_desc: [
		"Funciona como uma ferramenta &eelétrica&r de um Paxel, e tem alguns modos &dinteressantes&r:"
		""
		"- &cLento&r -> Funciona como uma ferramenta de &bdiamante&r"
		""
		"- &6Normal&r -> Funciona como uma ferramenta de &bdiamante&r com &deficiência&r 2"
		""
		"- &eRápido&r -> Funciona como uma ferramenta de &bdiamante&r com &deficiência&r 5"
		""
