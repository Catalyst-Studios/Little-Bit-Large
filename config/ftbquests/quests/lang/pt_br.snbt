	quest.35C209E20C000AA5.quest_subtitle: "hidrofobia, mas em blocos"
	quest.35C209E20C000AA5.title: "&l&bHydro&cphobe"
	quest.35DF9A15779E8AE4.quest_desc: [
		"Esta é a ferramenta mais &dimportante&r do &emod&r, permitindo que você &binteraja&r com todos os tipos de &5máquinas&r e canos."
