	quest.0D052E525AAEE0E2.title: "Missões"
	quest.0D1919E6F8066E9E.quest_desc: [
		"Você precisa de todos os itens para fazer corretamente."
		"Coloque o &5ponto de acesso sem fio&r em algum lugar da sua &drede principal&r e vincule seu terminal de criação sem fio dentro do &5ponto de acesso&r."
		""
		"Depois disso, coloque o &acartão quântico&r e depois a &esingularidade vinculada&r no canto superior direito."
		""
		"Agora, quebre o &5ponto de acesso&r, carregue o terminal sem fio e você terá o melhor terminal sem fio."
		""
		"Se você conectou o &danel quântico&r da última missão à sua rede principal, é claro...."
	]
	quest.0D1919E6F8066E9E.quest_subtitle: "Finalmente, &cSem Fio"
	quest.0D205F4DB23CF931.quest_desc: ["O &dCajado do Necromante&r é uma das minhas ferramentas favoritas em todo o Evilcraft. Podemos invocar zumbis para nos proteger de danos recebidos e sobrepujar nossos inimigos... No entanto, ainda precisamos de sangue para usar este cajado..."]
	quest.0D20B269523C1B70.quest_desc: ["Usando o &dmétodo&r de 1 bloco para 9 circuitos impressos, estamos economizando muito tempo!"]
	quest.0D20B269523C1B70.quest_subtitle: "Verifique as missões do ExtendedAE também"
	quest.0D20B269523C1B70.title: "Circuito Quântico Impresso"
	quest.0D7F28967280B814.quest_desc: ["Se você seguiu as missões das &6abelhas&r, você só precisa de 2 &6abelhas&r para conseguir esta e alguns materiais ;)"]
	quest.0D7F28967280B814.quest_subtitle: "Apenas 3 abelhas"
	quest.0D968517AACAB080.quest_subtitle: "Mega armazenamento"
	quest.0DACD6F3077FBD20.quest_desc: [
		"Os Geradores Apóticos permitem que você modifique Geradores para torná-los mais rápidos e eficientes!"
		""
		"Pegue qualquer Gerador usando uma picareta com &bToque Suave&r!"
		""
		"Você pode mudar o mob gerado clicando com o botão direito no gerador com seu ovo de geradores."
		""
		"&aDica:&r Você também pode usar as &bCaixas de Papelão do Mekanism&r para pegar geradores!"
	]
	quest.0DACD6F3077FBD20.title: "Geradores Apóticos!"
	quest.0DB2F08E593B2B93.quest_desc: [
		"Agora vamos precisar de um &dAmetista em Botão&r, felizmente o Apothic Enchanting nos dá uma receita de infusão!"
		""
		"Coloque &b10x Estantes de Mar Cristalino&r e &25x Estantes de Livros Normais&r, depois infunda um &dBloco de Ametista&r!"
	]
	quest.0DB2F08E593B2B93.title: "&5Ametista em Botão"
	quest.0DB34FF7DC6B31CC.title: "Abelha de Faixa Azul"
	quest.0DB992CAB5B99494.quest_desc: ["Em vez de favos, você obtém blocos, que são 4 favos, mas eles também são bem caros"]
	quest.0DB992CAB5B99494.quest_subtitle: "Em blocos"
	quest.0DC883B46880A03C.quest_desc: ["Encante uma arma com &bCaptura&r para ter a chance de obter seu ovo de gerador!"]
	quest.0DC883B46880A03C.quest_subtitle: "Quem veio primeiro? A galinha ou o ovo?"
	quest.0DC883B46880A03C.title: "Obtendo Ovos de Geradores"
	quest.0DF3C82DFF5E308A.quest_desc: [
		"Para começar com o Ars Nouveau, você precisará obter algumas tábuas de Archwood."
		""
		"As árvores de Archwood aparecem raramente pelo mapa, mas também abundantemente no bioma: florestas de Archwood."
		""
		"No momento, o tipo de árvore não importa e mais tarde você poderá transmutar uma muda de árvore em outra."
		""
		"&4nota! Se você encontrar frutas crescendo nessas árvores, certifique-se de levar algumas com você, pois podem ser úteis mais tarde.&r"
		"&4As frutas podem ser cultivadas como sementes de cacau e cada tipo de árvore tem sua própria variante.&r"
	]
	quest.0DF3C82DFF5E308A.quest_subtitle: "Madeira Elemental"
	quest.0DF7413E300B22CD.quest_desc: [
		"Você &lnão&r tem permissão para usar estas missões em nenhum modpack público sem &4&npermissão explícita&r da Catalyst Studios."
		""
		"Linha de missões de &bFunctional Storage&r feita por: &dHancock4903&r e &cTito&ep&c54&r"
		""
		"Se você está vendo isso, significa que está no modo de edição."
	]
	quest.0DF7413E300B22CD.quest_subtitle: "Estas missões incríveis foram feitas para a &4Catalyst Studios&r"
	quest.0DF7413E300B22CD.title: "&l&4Missões da Catalyst Studios"
	quest.0E2D84ED1157150E.quest_desc: ["Você precisa estar em um &bioma frio&r, e &6guloseimas de mel&r"]
	quest.0E2D84ED1157150E.quest_subtitle: "O verdadeiro açúcar"
	quest.0E42A6572FA858A2.quest_desc: [
		"O gabinete armazena quase todas as &dferramentas&r e &5armaduras&r do jogo."
		""
		"Isso pode &4destruir&r seu mundo se você &earmazenar&r muito &blixo&r"
	]
	quest.0E42A6572FA858A2.quest_subtitle: "&cdestruidor&r de NBT"
	quest.0E77237CFA4F41F5.quest_desc: [
		"Isso age como 2 &abarris&r, mas em apenas 1 bloco, &eútil&r se você me perguntar."
		""
		"Custa apenas algumas &7barras de ferro&r ou se você quiser &aeconomizar&r algumas delas, pode usar aquele baú de &6cobre&r se tiver muito &6cobre&r"
	]
	quest.0E77237CFA4F41F5.quest_subtitle: "A fazenda de peixes"
	quest.0E8C2C8D2D00843A.quest_desc: [
		"Se você pensou que só existiam Promessas que aumentavam a capacidade interna do tanque, então você está errado."
		""
		"A &4Promessa de Velocidade&r acelera qualquer bloco funcional do Evilcraft por um modificador de 2x. Isso ajudará bastante a reduzir o tempo de processo do nosso Infusor de Sangue."
		""
		"A &9Promessa de Produtividade&r diminui a quantidade de sangue usada em cada processo por 1.5x, tornando-o mais eficaz."
		""
		"Podemos fazer uma combinação dessas promessas para 'melhorar' nossas máquinas/blocos para um melhor desempenho em cada processo, existem 3 slots para essas promessas, então vá em frente e veja o que é melhor para suas máquinas!"
	]
	quest.0E8C2C8D2D00843A.title: "Promessas Úteis"
	quest.0E96A0AEBFCAD34D.quest_desc: ["A &5Estante de Livros de Estabilidade Encapsulada em Geodo&r fornece &6Estabilidade Quântica&r, o que significa que você tem praticamente a &ogarantia&r de obter encantamentos de alto nível!"]
	quest.0E96A0AEBFCAD34D.quest_subtitle: "Encantamentos de baixo nível, desapareçam!"
	quest.0E96A0AEBFCAD34D.title: "&5Estante de Livros de Estabilidade Encapsulada em Geodo"
	quest.0EB614A5D08D59BD.title: "Capacete Solar &l&5V7"
	quest.0EF171C9D1A27B99.quest_desc: [
		"O PNC vem com um aldeão útil que troca tudo o que você pode precisar, exceto plástico. Na verdade, ele é tão bom que, se você tiver estes, nem precisa construir uma câmara de pressão."
		""
