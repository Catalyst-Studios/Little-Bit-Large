		""
		"[{\"text\":\"- Se você é mais um \",\"color\":\"#FFFFFF\"},{\"text\":\"aprendiz\",\"color\":\"#55FF55\"},{\"text\":\" visual, você pode \",\"color\":\"#FFFFFF\"},{\"text\":\"conferir\",\"color\":\"#AA00AA\"},{\"text\":\" \",\"color\":\"#FFFFFF\"},{\"text\":\"aqui\",\"color\":\"#FF55FF\",\"underlined\":true,\"hoverEvent\":{\"action\":\"show_text\",\"value\":{\"text\":\"Clique aqui para abrir um vídeo no Youtube\"}},\"clickEvent\":{\"action\":\"open_url\",\"value\":\"https://www.youtube.com/watch?v=esz5FVA-fY0\"}}]"
