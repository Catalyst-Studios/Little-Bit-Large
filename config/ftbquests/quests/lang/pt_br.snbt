	quest.6D36292892EA5781.title: "Capacete Solar &l&7V2"
	quest.6D367B4E977C72E9.quest_desc: ["Como os cabos &aUniversais&r, mais &bcanos&r = melhor &6capacidade&r e melhor &dtaxa de transferência&r"]
	quest.6D367B4E977C72E9.quest_subtitle: "Movendo &9fluidos&r"
	quest.6D4FB5CE5BA905D2.quest_desc: [
		"Assim como as &bEstantes Marinhas&r, as &9Estantes Profundas Ecoantes&r fornecem maior &aEterna&r e &5Arcana&r!"
