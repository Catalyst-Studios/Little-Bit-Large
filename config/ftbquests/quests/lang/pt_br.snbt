	quest.04BA44C84D598B0C.quest_subtitle: "prospecção"
	quest.04BD576CE4947F1A.quest_desc: ["Permite que você &dbombeie&r &axp&r, só isso"]
	quest.050FD0FD25FB652B.quest_desc: [
