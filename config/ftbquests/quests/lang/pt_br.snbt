	quest.01C22467B074967C.quest_desc: [
		"A estrutura de calor pode ser colocada em cima de qualquer inventário e é usada para criar obsidiana, gelo e plástico "
		""
		"Para fazer isso, você precisará manter a estrutura abaixo da temperatura de solidificação do que quer que esteja tentando fazer, o que é explicado nas missões de calor anteriores"
		""
		"Os tanques do pnc são úteis para isso, pois eles comportam vários baldes, então você não precisa ficar lá trocando baldes o dia todo."
	]
	quest.01C22467B074967C.quest_subtitle: "Banho de gelo"
