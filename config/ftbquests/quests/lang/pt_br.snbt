	quest.60740A1E3AA2402E.quest_desc: ["3 &6baús&r em uma única &amochila&r? E &dcustando&r apenas &eouro&r?"]
	quest.60740A1E3AA2402E.quest_subtitle: "Sua base em uma mochila"
	quest.609A6A3D7542871A.quest_desc: ["Permite que você &dcomprima&r e &6descomprima&r automaticamente, como você precisando de pó de &credstone&r, mas só tendo &6blocos&r de &credstone&r ou vice-versa"]
	quest.609A6A3D7542871A.quest_subtitle: "Melhor amigo?"
	quest.60A2AE588A7D600C.quest_desc: [
		"Energia: &cLIGADA&r"
		"Capacidade necessária: &4ERRO&r"
		""
		"Sim, basicamente isso, você precisa de muitos &acanais&r e &eenergia&r, muitos mesmo"
