	quest.0AC4D069AEA88579.quest_desc: [
		"Para obter nosso primeiro bloco de Sangue Endurecido, podemos usar 2 métodos..."
		""
		"{ \"text\": \"1.- Dando uma olhada nesta missão\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"47C942BC0BD3D01E\" } }"
		""
		"2.- Fazendo o método original, que exige que o jogador pegue um balde de &csangue&r e deixe secar. Este evento no mundo pode levar um pouco de tempo, mas uma vez que o sangue endureça, você precisará quebrá-lo usando um &ePederneira e Aço&r. Cuidado, se você quebrar este bloco com a mão ou com qualquer ferramenta, ele se transformará em um fluido e, se a chuva o tocar, ele também se transformará em um fluido mais uma vez..."
	]
	quest.0AC4D069AEA88579.title: "Secando Nosso Sangue"
	quest.0AE1D9E720C989FD.quest_desc: [
