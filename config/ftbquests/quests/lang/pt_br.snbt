	quest.150301896889C39C.quest_subtitle: "Trazendo"
	quest.151BBAA83E037C27.quest_desc: [
		"Se houver algo que as missões não cobrem e sobre o qual você tenha dúvidas, você pode encontrar aqui."
		""
		"Se você tiver o Livro em seu inventário, poderá passar o mouse sobre um item e segurar Ctrl, e isso o levará diretamente às páginas sobre o item escolhido."
