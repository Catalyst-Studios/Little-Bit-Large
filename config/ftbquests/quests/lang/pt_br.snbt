	quest.41B3A0FD5859D510.quest_desc: [
		"O golem de ametista é uma criatura que irá colher ametistas totalmente crescidas. Normalmente, eles quebram os brotos; no entanto, em uma área reivindicada, eles não os quebrarão, mas ainda assim os colherão, fazendo-os funcionar significativamente mais rápido."
		""
		"Golems de ametista também criarão ametistas em brotação a partir de ametistas normais."
	]
	quest.421B57E27B2E9F61.quest_desc: [
		"Você pode usar uma vara em uma colmeia para fazer as abelhas saírem, mas elas não vão gostar...."
		""
		"Você precisa usar o clique esquerdo"
	]
	quest.421B57E27B2E9F61.quest_subtitle: "\"BATE NELA, BATE NELA\""
	quest.424808BE0E48D8C7.quest_desc: [
