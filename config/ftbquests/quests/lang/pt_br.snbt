	quest.40501DAE73600660.quest_desc: ["Coloque uma bomba &aelétrica&r com uma melhoria de &dfiltro&r sobre a &9água&r"]
	quest.4055D1BC0E7E2C21.quest_desc: [
		"Esta configuração \"Deveria™\" funcionar para qualquer receita no aparato de encantamento."
		""
		"Ela usa uma sub-rede com um porta de armazenamento de alta prioridade no roteador, o que garante que o item que vai para o centro seja sempre enviado para lá."
		""
		"&6Para que isso funcione, você precisa ter o item indo para o aparato primeiro no padrão (espaço superior esquerdo), que geralmente é a receita padrão importada no terminal de configuração de padrões.&r"
		""
		"&6O modo de bloqueio ou travamento é necessário para esta configuração.&r"
		""
		"O roteador retira o item do aparato quando o processo termina, o que permite que o coletor o pegue."
		""
		"Para mais informações sobre sub-redes, verifique as missões do AE."
		"{image:catalyst:textures/quest_images/ars_nouveau/enchanting_apparatus_auto.png width:100 height:150 align:center}"
	]
	quest.4055D1BC0E7E2C21.title: "Encantador Automático"
	quest.40621C71E36A7549.quest_desc: ["Basicamente, &dpermite&r que você &carmazene&r 4 vezes mais em cada &6espaço&r"]
	quest.40621C71E36A7549.quest_subtitle: "Pedregulho comprimido 9 vezes"
	quest.40703D01AED88444.quest_desc: ["Bem, o que posso dizer aqui?"]
	quest.40703D01AED88444.quest_subtitle: "Sim, nerfado também"
	quest.40732110998F3FF3.quest_desc: ["Basicamente, &dpermite&r que você &carmazene&r 2 vezes mais em cada &6espaço&r"]
