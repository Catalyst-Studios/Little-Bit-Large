	quest.6C504AA720E7C1C3.quest_subtitle: "Limite inferior"
	quest.6C504AA720E7C1C3.title: "Atraso Mínimo de Geração"
	quest.6C6D6015BDFF4BD3.quest_desc: [
		"Esta é a &bmáquina AE2&r que permite usar &carmazenamento&r de outros mods."
		"Ela usa 1 &acanal&r e só pode ser colocada em &dcabos inteligentes&r."
		""
		"Eles têm funcionalidades legais na GUI, então dê uma olhada, mas as importantes são:"
		""
		"- &aFiltragem&r: Para que 500 coisas diferentes não vão para a mesma coisa"
		""
		"- &dExtração&r: Você pode configurá-los para apenas extrair ou apenas inserir ou ambos"
	]
	quest.6C6D6015BDFF4BD3.quest_subtitle: "Armazenando em outros mods? Você está me traindo?"
	quest.6C6E3917998083C9.quest_desc: [
		"Você &lnão&r tem permissão para usar estas missões em qualquer pacote público sem &4&npermissão explícita&r da Catalyst Studios."
