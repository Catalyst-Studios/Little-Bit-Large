	quest.25CED87D758A6D0C.quest_subtitle: "Um por outro"
	quest.261C1726C965B33F.quest_desc: ["São basicamente &3inúteis&r, já que você tem o &aMekanism&r para o enlatador e não usa o reparo para brotos, já que você tem &6abelhas&r ou &dduplicação&r para o cristal de &aEntro&r ou broto &eperfeito&r para o &bcertus&r"]
