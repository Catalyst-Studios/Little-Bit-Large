	]
	quest.018A9B49A3D7066F.title: "&lAddon de Proxy de Inventário de Máquina"
	quest.01948A35B9155A51.quest_desc: ["Este orbe será uma das primeiras criações que faremos no &cInfusor de Sangue&r."]
	quest.01AC9F09A84155B8.quest_desc: [
