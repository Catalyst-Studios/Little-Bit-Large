	quest.2172EDCAEFA96592.quest_desc: ["Útil apenas se você tiver abelhas do ender sem simulação, o que você não deveria ter"]
	quest.2172EDCAEFA96592.quest_subtitle: "Apenas abelhas do ender"
	quest.21840AA523363D90.quest_desc: [
		"Apenas &areduza&r o som no menu de &dconfigurações&r."
		""
		"Há também um &balto-falante&r no seu &cinventário&r que faz o mesmo, mas para sons &6individuais&r"
