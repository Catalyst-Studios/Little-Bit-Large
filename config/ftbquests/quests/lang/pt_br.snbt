	quest.5F2DA93190331483.quest_desc: [
		"Este é um ingrediente de &6criação&r e uma &dmáquina&r, usada para mover &eitens&r, &9fluidos&r, ... por longas &cdistâncias&r (não mais que 30 - 50 blocos)."
