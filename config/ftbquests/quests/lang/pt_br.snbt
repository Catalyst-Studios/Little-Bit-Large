	quest.0922550FAAE06AD9.quest_desc: [
		"Primeiro nível de energia &6solar&r, e é um &bbom&r começo para este &amod&r e outros."
		""
		"Preciso &ddizer&r que eles &cnão&r funcionam durante a &enoite&r?"
	]
	quest.0922550FAAE06AD9.quest_subtitle: "Energia solar"
	quest.0925EFA03EAFF209.quest_desc: [
		"Esta é a sua principal forma de processar favos do mod Productive Bees."
		""
		"&cNão processe favos de abelhas normais.&r"
		""
		"Temos 3 centrífugas, a primeira só pode ser usada pelo jogador, então vamos pular essa."
		""
		"As outras 2 centrífugas precisam de energia e podem ser usadas por outros sistemas de automação, como &cS&r&eF&r&cM&r ou &bAE2&r."
		""
		"Embora sejam basicamente as mesmas, existem 3 diferenças principais:"
		""
		"- A &dcentrífuga&r &caquecida&r funciona mais rápido"
		""
		"- A &dcentrífuga&r &caquecida&r não renderiza favos (menos lag)"
		""
		"- A &dcentrífuga&r &caquecida&r não gera cera"
	]
	quest.0925EFA03EAFF209.quest_subtitle: "SFM ativado"
	quest.092767A2A7AC588C.quest_desc: ["Necessário para a carcaça, basicamente"]
	quest.092767A2A7AC588C.quest_subtitle: "Carcaça concluída?"
	quest.092873428BF87547.quest_desc: ["Você vai &cprecisar&r de um pouco de &bágua&r para começar"]
	quest.0939481C74A10264.quest_desc: [
		"Isso é, infelizmente, apenas 2 &abaús&r &dduplos&r."
		""
		"Mas pelo menos você tem 4 &dmelhorias&r"
